# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron auth (Project Settings → Environment Variables).
# Vercel sends Authorization: Bearer <CRON_SECRET> on scheduled invocations.
# Use a random string of at least 16 characters.
CRON_SECRET=your-cron-secret

# Public short-link + app origin (no trailing slash)
# Also used for Supabase invite redirect URLs — set the same value as Site URL in Supabase Auth
NEXT_PUBLIC_SHORT_LINK_DOMAIN=https://url-shorten-sooty.vercel.app
